# Backend environment — copy to .env and adjust
ENVIRONMENT=dev
DEBUG=true

# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://home_agent:home_agent@localhost:5432/home_agent

# Exact origins consumed by app.core.config via JSON list parsing
CORS_ORIGINS=["http://localhost:5173"]
# Regex for LAN clients in addition to exact origins (private IPs + .local hosts on :5173/:8000)
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|[a-zA-Z0-9-]+\.local):(5173|8000)$

# Claude
ANTHROPIC_API_KEY=
# Per-agent model routing (JSON dict). Defaults live in app.core.config.
# AGENT_MODELS={"orchestrator":"claude-sonnet-4-6","schedule":"claude-haiku-4-5","todo":"claude-sonnet-4-6","ledger":"claude-haiku-4-5","finance":"claude-opus-4-7","ideas":"claude-sonnet-4-6","files":"claude-sonnet-4-6"}

# Google Calendar OAuth (read-only sync)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_CALENDAR_ID=primary
